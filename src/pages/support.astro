---
import LegalPage from '../layouts/LegalPage.astro';
---
<LegalPage
  title="Support - CrushCue"
  description="Get help with CrushCue. Contact us for subscription questions, account access, bug reports, or feedback."
  footerLinks={[
    { href: '/privacy', label: 'Privacy Policy' },
    { href: '/terms', label: 'Terms of Service' },
  ]}
>
  <h1>Support</h1>

  <p>
    Need help with CrushCue? We're here for you.
  </p>

  <div class="section">
    <h2>Contact Us</h2>
    <p>
      For any questions, issues, or feedback, please email us at:
    </p>
    <p class="email">contact@crushcue.app</p>
  </div>

  <div class="section">
    <h2>Common Topics</h2>
    <p>
      • Subscription issues or billing questions<br />
      • Restoring purchases<br />
      • Account access problems<br />
      • Bug reports or app issues<br />
      • Feedback and feature requests
    </p>
  </div>

  <div class="section">
    <h2>Response Time</h2>
    <p>
      We typically respond within 24–48 hours.
    </p>
  </div>
</LegalPage>

<style>
  h1 {
    margin: 0 0 14px;
    font-size: 36px;
    letter-spacing: -0.04em;
  }

  h2 {
    margin-top: 28px;
    font-size: 18px;
  }

  p {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 14px;
  }

  .email {
    color: var(--primary);
    font-weight: 700;
    font-size: 16px;
  }

  .section {
    margin-top: 28px;
  }

  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }
  }
</style>
