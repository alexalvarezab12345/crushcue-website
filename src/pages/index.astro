---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const APP_STORE = 'https://apps.apple.com/ro/app/crushcue-ai/id6764087079';
const SCREENSHOT = '/images/screenshots/crushcue-analysis-withdrawal.png';

const allArticles = await getCollection('seo');
const latestArticles = allArticles
  .filter(a => a.data.status === 'published')
  .sort((a, b) =>
    new Date(b.data.generatedAt ?? '').getTime() -
    new Date(a.data.generatedAt ?? '').getTime()
  )
  .slice(0, 6);

const useCases = [
  {
    title: 'Mixed Signals',
    desc: 'Warm one day, cold the next. CrushCue reads whether it\'s uncertainty or avoidance.',
    href: '/mixed-signals-in-dating-decoded',
  },
  {
    title: 'Ghosting',
    desc: 'They vanished. CrushCue tells you what the silence actually means.',
    href: '/why-people-ghost-explained',
  },
  {
    title: 'Left on Read',
    desc: 'They saw it. CrushCue tells you whether to follow up or let it sit.',
    href: '/left-on-read-what-it-means',
  },
  {
    title: 'Situationships',
    desc: 'No label, real feelings. CrushCue reads where it\'s actually headed.',
    href: '/situationship-signs-and-meaning',
  },
  {
    title: 'What To Text',
    desc: 'Staring at a blank message. CrushCue tells you exactly what to say — and what not to.',
    href: '/what-to-text-them-guide',
  },
];
---

<Base
  title="CrushCue — Read the situation clearly"
  description="Paste your conversation. CrushCue reads the signals — mixed messages, ghosting, left on read — and tells you exactly where you stand."
  ogTitle="CrushCue — Finally know what's actually going on"
  ogDescription="AI that reads dating situations clearly. No guessing. No generic advice."
>

<!-- Ambient background orbs -->
<div class="ambient" aria-hidden="true">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>

<!-- ── Nav ── -->
<nav class="nav" id="nav">
  <div class="nav-inner">
    <span class="nav-logo">CrushCue</span>
    <a class="nav-cta" href={APP_STORE}>Get the app</a>
  </div>
</nav>

<!-- ── Hero ── -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        AI for modern dating
      </div>
      <h1 class="hero-h1">
        Finally know<br/>
        <em class="hero-h1-em">what's actually going on.</em>
      </h1>
      <p class="hero-sub">
        Paste your conversation. CrushCue reads the signals —
        mixed messages, ghosting, left on read — and tells you
        exactly where you stand.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href={APP_STORE}>
          <span class="btn-label">Download CrushCue Free</span>
        </a>
        <p class="hero-note">Free to try · App Store · No account needed</p>
      </div>
    </div>

    <div class="hero-phone-wrap phone-float">
      <div class="phone-shell hero-phone">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <img
            src={SCREENSHOT}
            alt="CrushCue conversation analysis"
            class="phone-img"
            loading="eager"
            width="220"
          />
        </div>
      </div>
      <div class="phone-glow"></div>
    </div>
  </div>
</section>

<!-- ── How It Works ── -->
<section class="hiw-section">
  <div class="container">
    <p class="eyebrow reveal">Simple process</p>
    <h2 class="section-h2 reveal" style="--delay:80ms">How CrushCue works</h2>
    <div class="hiw-steps">
      <div class="hiw-card reveal" style="--delay:0ms">
        <span class="hiw-num">01</span>
        <h3 class="hiw-title">Paste the situation</h3>
        <p class="hiw-desc">Screenshot, copy-paste, or describe what happened. No cleanup needed.</p>
      </div>
      <div class="hiw-line reveal" style="--delay:160ms"></div>
      <div class="hiw-card reveal" style="--delay:160ms">
        <span class="hiw-num">02</span>
        <h3 class="hiw-title">Get the read</h3>
        <p class="hiw-desc">CrushCue reads signal type, timing, and engagement arc. Specific, not generic.</p>
      </div>
      <div class="hiw-line reveal" style="--delay:320ms"></div>
      <div class="hiw-card reveal" style="--delay:320ms">
        <span class="hiw-num">03</span>
        <h3 class="hiw-title">Know your next move</h3>
        <p class="hiw-desc">A clear recommendation for what to do — not what to feel.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Product Showcase ── -->
<section class="showcase-section">
  <div class="container showcase-inner reveal">
    <div class="hero-phone-wrap phone-float">
      <div class="phone-shell hero-phone">
        <div class="phone-notch"></div>
        <div class="phone-screen sc-screen">

          <div class="sc-status-bar">
            <span class="sc-time">9:41</span>
            <div class="sc-icons">
              <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                <rect x="0" y="3" width="2" height="5" rx="0.5" fill="rgba(255,255,255,0.5)"/>
                <rect x="2.5" y="2" width="2" height="6" rx="0.5" fill="rgba(255,255,255,0.65)"/>
                <rect x="5" y="1" width="2" height="7" rx="0.5" fill="rgba(255,255,255,0.8)"/>
                <rect x="7.5" y="0" width="2" height="8" rx="0.5" fill="white"/>
              </svg>
              <svg width="16" height="8" viewBox="0 0 16 8" fill="none">
                <rect x="0.5" y="0.5" width="13" height="7" rx="1.5" stroke="rgba(255,255,255,0.35)" stroke-width="1"/>
                <rect x="1.5" y="1.5" width="9" height="5" rx="0.5" fill="white"/>
                <rect x="14" y="2.5" width="1.5" height="3" rx="0.5" fill="rgba(255,255,255,0.35)"/>
              </svg>
            </div>
          </div>

          <div class="sc-app-header">
            <div class="sc-hdr-left">
              <div class="sc-app-icon"></div>
              <div>
                <p class="sc-app-name">CrushCue</p>
                <p class="sc-app-status">Ready when you are</p>
              </div>
            </div>
            <div class="sc-hdr-right">
              <span class="sc-vibe">Vibe</span>
              <span class="sc-refresh">↻</span>
            </div>
          </div>

          <div class="sc-chat">
            <div class="sc-bubble-row sc-user-row">
              <div class="sc-bubble sc-user-bubble">
                We had an amazing date. Now barely hears from them.
              </div>
            </div>
            <div class="sc-bubble-row sc-cc-row">
              <div class="sc-avatar"><span>C</span></div>
              <div class="sc-analysis">
                <div class="sc-signal-row">
                  <span class="sc-pill">Ambivalent interest</span>
                  <div class="sc-dots">
                    <span class="sc-dot sc-filled"></span>
                    <span class="sc-dot sc-filled"></span>
                    <span class="sc-dot"></span>
                  </div>
                </div>
                <div class="sc-divider"></div>
                <p class="sc-lbl">What it means</p>
                <p class="sc-means">Attracted but conflict-avoidant. Closeness triggered distance.</p>
                <div class="sc-rec">
                  <p class="sc-next">Match their energy. No first moves for 10 days.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="sc-input-bar">
            <div class="sc-input-placeholder">Paste the chat...</div>
            <div class="sc-input-send">↑</div>
          </div>

        </div>
      </div>
      <div class="phone-glow"></div>
    </div>

    <div class="showcase-copy">
      <p class="eyebrow">See it in action</p>
      <h2 class="section-h2">A specific read on any situation</h2>
      <p class="showcase-sub">
        CrushCue doesn't give you advice. It gives you a diagnosis —
        signal type, confidence level, what it actually means, and
        exactly what to do next.
      </p>
      <ul class="showcase-features">
        <li>
          <span class="feat-label">Signal type</span>
          Whether it's avoidance, mixed signals, or re-engagement
        </li>
        <li>
          <span class="feat-label">Confidence read</span>
          How clearly the pattern comes through
        </li>
        <li>
          <span class="feat-label">What it means</span>
          The honest interpretation, not the optimistic one
        </li>
        <li>
          <span class="feat-label">What to do next</span>
          One specific action, not a list of options
        </li>
      </ul>
    </div>
  </div>
</section>

<!-- ── Use Cases (marquee ticker) ── -->
<section class="use-section">
  <div class="container">
    <p class="eyebrow reveal">Common situations</p>
    <h2 class="section-h2 reveal" style="--delay:80ms">People use CrushCue when they need clarity</h2>
  </div>
  <div class="marquee-track" role="region" aria-label="Situations">
    <div class="marquee-inner">
      {useCases.map((u) => (
        <a class="use-card" href={u.href}>
          <h3 class="use-title">{u.title}</h3>
          <p class="use-desc">{u.desc}</p>
          <span class="use-link">Read more →</span>
        </a>
      ))}
      {useCases.map((u) => (
        <a class="use-card" href={u.href} aria-hidden="true" tabindex="-1">
          <h3 class="use-title">{u.title}</h3>
          <p class="use-desc">{u.desc}</p>
          <span class="use-link">Read more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── Latest Situations ── -->
<section class="latest-section">
  <div class="container">
    <p class="eyebrow reveal">From the CrushCue guide</p>
    <h2 class="section-h2 reveal" style="--delay:80ms">Latest situations decoded</h2>
    <div class="latest-list">
      {latestArticles.map((a, i) => (
        <a class="latest-item reveal" href={`/${a.id}`} style={`--delay:${i * 60}ms`}>
          <span class="latest-num">0{i + 1}</span>
          <div class="latest-text">
            <h3 class="latest-title">{a.data.title}</h3>
            {a.data.metaDescription && (
              <p class="latest-desc">{a.data.metaDescription}</p>
            )}
          </div>
          <span class="latest-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── Final CTA ── -->
<section class="final-section">
  <div class="final-inner reveal">
    <h2 class="final-h2">Stop guessing.</h2>
    <p class="final-sub">
      You deserve clarity. CrushCue gives you the actual read on
      what's happening — and exactly what to do next.
    </p>
    <a class="btn-primary btn-lg" href={APP_STORE}>
      <span class="btn-label">Get the read</span>
    </a>
    <p class="final-note">Free · App Store · No account needed</p>
  </div>
</section>

<!-- ── Footer ── -->
<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-logo">CrushCue</span>
    <div class="footer-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="mailto:contact@crushcue.app">Contact</a>
    </div>
    <span class="footer-copy">© 2026 CrushCue</span>
  </div>
</footer>

</Base>

<style>
/* ── Reset & base ── */
* { box-sizing: border-box; }

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ── Ambient drifting orbs ── */
.ambient {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
  will-change: transform;
}

.orb-1 {
  width: 700px; height: 700px;
  top: -20%; left: -15%;
  background: radial-gradient(circle, rgba(109,40,217,0.22) 0%, transparent 65%);
  animation: orb-drift-1 28s ease-in-out infinite;
}

.orb-2 {
  width: 600px; height: 600px;
  bottom: -15%; right: -10%;
  background: radial-gradient(circle, rgba(67,20,140,0.18) 0%, transparent 65%);
  animation: orb-drift-2 35s ease-in-out infinite;
}

.orb-3 {
  width: 400px; height: 400px;
  top: 40%; left: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 65%);
  animation: orb-drift-3 22s ease-in-out infinite;
}

@keyframes orb-drift-1 {
  0%, 100% { transform: translate(0,   0)   scale(1);    }
  33%       { transform: translate(80px, 60px)  scale(1.12); }
  66%       { transform: translate(-30px, 40px) scale(0.95); }
}
@keyframes orb-drift-2 {
  0%, 100% { transform: translate(0,    0)    scale(1);    }
  33%       { transform: translate(-70px,-80px) scale(1.08); }
  66%       { transform: translate(50px, -30px) scale(1.1);  }
}
@keyframes orb-drift-3 {
  0%, 100% { transform: translate(0,   0)   scale(1);    }
  50%       { transform: translate(40px,-50px) scale(1.15); }
}

/* ── Phone float ── */
@keyframes phone-float {
  0%, 100% { transform: translateY(0px);   }
  50%       { transform: translateY(-14px); }
}
.phone-float {
  animation: phone-float 6s ease-in-out infinite;
  will-change: transform;
}

/* ── Scroll reveal ── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity  0.72s cubic-bezier(0.16, 1, 0.3, 1),
    transform 0.72s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: var(--delay, 0ms);
}
.reveal.in-view {
  opacity: 1;
  transform: translateY(0);
}

/* ── Eyebrow ── */
.eyebrow {
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8b5cf6;
  margin: 0 0 12px;
}

/* ── Section heading ── */
.section-h2 {
  font-size: clamp(26px, 3.2vw, 38px);
  font-weight: 800;
  letter-spacing: -0.045em;
  color: #f4f0ff;
  line-height: 1.15;
  margin: 0 0 14px;
}

/* ── Primary CTA button ── */
.btn-primary {
  display: inline-flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 14px 28px;
  background: #7c3aed;
  color: #fff;
  text-decoration: none;
  font-size: 14.5px;
  font-weight: 700;
  letter-spacing: -0.01em;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.12);
  box-shadow:
    0 0 0 0 rgba(139, 92, 246, 0),
    inset 0 1px 0 rgba(255,255,255,0.15);
  transition:
    transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
    box-shadow 0.25s ease,
    background 0.25s ease;
  white-space: nowrap;
}

/* Shimmer sweep */
.btn-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 35%, rgba(255,255,255,0.18) 50%, transparent 65%);
  transform: translateX(-100%);
  transition: transform 0.55s ease;
}

.btn-primary:hover::before { transform: translateX(100%); }

.btn-primary:hover {
  transform: translateY(-2px) scale(1.025);
  background: #6d28d9;
  box-shadow:
    0 0 0 4px rgba(139, 92, 246, 0.2),
    0 8px 30px rgba(109, 40, 217, 0.4),
    inset 0 1px 0 rgba(255,255,255,0.2);
}

.btn-primary:active { transform: translateY(0) scale(1); }

.btn-lg { padding: 16px 36px; font-size: 16px; }

/* ── Phone shell ── */
.phone-shell {
  background: #141420;
  border: 1.5px solid rgba(255,255,255,0.1);
  border-radius: 38px;
  box-shadow:
    0 0 0 1px rgba(0,0,0,0.5),
    0 32px 80px rgba(0,0,0,0.55),
    0 8px 24px rgba(0,0,0,0.3);
  position: relative;
}

.phone-notch {
  background: rgba(255,255,255,0.07);
  border-radius: 999px;
  margin: 0 auto;
}

.phone-screen {
  border-radius: 24px;
  overflow: hidden;
  background: #0c0c12;
}

.phone-img { width: 100%; display: block; }

/* Glow pulse */
@keyframes glow-pulse {
  0%, 100% { opacity: 0.55; transform: scale(1); }
  50%       { opacity: 0.75; transform: scale(1.06); }
}

.phone-glow {
  position: absolute;
  inset: -40px;
  background: radial-gradient(circle at center, rgba(109,40,217,0.22), transparent 68%);
  pointer-events: none;
  z-index: -1;
  animation: glow-pulse 6s ease-in-out infinite;
  will-change: opacity, transform;
}

/* ── Nav ── */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10,10,16,0);
  border-bottom: 1px solid transparent;
  transition: background 0.4s ease, border-color 0.4s ease;
}

.nav.scrolled {
  background: rgba(10,10,16,0.82);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom-color: rgba(255,255,255,0.05);
}

.nav-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.04em;
  color: #f4f0ff;
}

.nav-cta {
  padding: 8px 18px;
  background: rgba(124,58,237,0.15);
  color: #c4b5fd;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid rgba(139,92,246,0.3);
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}

.nav-cta:hover {
  background: #7c3aed;
  color: #fff;
  border-color: #7c3aed;
}

/* ── Hero ── */
.hero {
  min-height: 92vh;
  display: flex;
  align-items: center;
  padding: 80px 32px 100px;
  max-width: 1100px;
  margin: 0 auto;
}

.hero-inner {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: 80px;
  align-items: center;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 12px 5px 8px;
  background: rgba(109,40,217,0.12);
  border: 1px solid rgba(139,92,246,0.22);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: #a78bfa;
  margin-bottom: 20px;
}

.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #8b5cf6;
  animation: badge-pulse 2.5s ease-in-out infinite;
}

@keyframes badge-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}

.hero-h1 {
  font-size: clamp(40px, 5.2vw, 66px);
  font-weight: 900;
  letter-spacing: -0.055em;
  line-height: 1.07;
  color: #f4f0ff;
  margin: 0 0 20px;
  font-style: normal;
}

.hero-h1-em {
  font-style: normal;
  color: #a78bfa;
}

.hero-sub {
  font-size: 17px;
  font-weight: 400;
  color: #7e7a96;
  line-height: 1.72;
  margin: 0 0 36px;
  max-width: 460px;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
}

.hero-note {
  margin: 0;
  font-size: 11.5px;
  color: #4d4866;
  letter-spacing: 0.01em;
}

.hero-phone-wrap {
  position: relative;
  display: flex;
  justify-content: center;
}

.hero-phone {
  width: 240px;
  padding: 15px 10px;
}

.hero-phone .phone-notch {
  width: 60px;
  height: 7px;
  margin-bottom: 12px;
}

/* ── How It Works ── */
.hiw-section {
  padding: 110px 0;
  border-top: 1px solid rgba(255,255,255,0.04);
}

.hiw-steps {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 48px;
}

.hiw-card {
  flex: 1;
  padding: 28px 26px;
  background: rgba(18,18,26,0.7);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 20px;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: border-color 0.3s, background 0.3s;
}

.hiw-card:hover {
  border-color: rgba(139,92,246,0.2);
  background: rgba(22,22,32,0.85);
}

.hiw-line {
  width: 40px;
  flex-shrink: 0;
  height: 1px;
  background: linear-gradient(90deg, rgba(139,92,246,0.2), rgba(139,92,246,0.05));
}

.hiw-num {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #6d28d9;
  margin-bottom: 14px;
  font-feature-settings: 'tnum';
}

.hiw-title {
  font-size: 15px;
  font-weight: 700;
  color: #f4f0ff;
  margin: 0 0 8px;
  letter-spacing: -0.02em;
}

.hiw-desc {
  font-size: 13.5px;
  color: #6b667f;
  line-height: 1.65;
  margin: 0;
}

/* ── Showcase phone interior ── */
.sc-screen {
  display: flex;
  flex-direction: column;
}

.sc-status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 12px 4px;
  background: #12121a;
}

.sc-time {
  font-size: 9px;
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.01em;
}

.sc-icons { display: flex; align-items: center; gap: 4px; }

.sc-app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 12px 8px;
  background: #12121a;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}

.sc-hdr-left { display: flex; align-items: center; gap: 6px; }

.sc-app-icon {
  width: 20px;
  height: 20px;
  border-radius: 5px;
