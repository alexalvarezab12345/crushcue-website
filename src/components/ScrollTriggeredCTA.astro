---
const APP_STORE = 'https://apps.apple.com/ro/app/crushcue-ai/id6764087079';
---

<div class="scroll-cta" id="scroll-triggered-cta" aria-hidden="true">
  <div class="scroll-cta-inner">
    <div class="scroll-cta-text">
      <p class="scroll-cta-headline">Still thinking about it?</p>
      <p class="scroll-cta-sub">Get the actual read in under 60 seconds.</p>
    </div>
    <a class="scroll-cta-button" href={APP_STORE}>Try CrushCue Free</a>
  </div>
</div>

<script>
  const el = document.getElementById('scroll-triggered-cta');
  if (el) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          el.removeAttribute('aria-hidden');
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(el);
  }
</script>

<style>
  .scroll-cta {
    margin: 36px 0 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    pointer-events: none;
  }

  .scroll-cta.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .scroll-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding: 20px 24px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.10), rgba(167, 139, 250, 0.07));
    border: 1px solid rgba(167, 139, 250, 0.22);
    border-radius: 16px;
  }

  .scroll-cta-text {
    flex: 1;
    min-width: 180px;
  }

  .scroll-cta-headline {
    margin: 0 0 3px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.3;
  }

  .scroll-cta-sub {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.4;
  }

  .scroll-cta-button {
    display: inline-block;
    padding: 10px 22px;
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.3);
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .scroll-cta-button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  @media (max-width: 480px) {
    .scroll-cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .scroll-cta-button {
      width: 100%;
      text-align: center;
    }
  }
</style>
