---
const steps = [
  {
    n: '1',
    label: 'Describe your situation',
    detail: 'Paste messages or describe what happened. No editing needed.',
  },
  {
    n: '2',
    label: 'CrushCue reads the pattern',
    detail: 'Signal type, timing, and engagement arc — analyzed in seconds.',
  },
  {
    n: '3',
    label: 'Get a specific read',
    detail: "Not advice. A diagnosis of what’s actually happening and what to do.",
  },
];
---

<div class="how-it-works">
  <p class="hiw-label">How it works</p>
  <div class="hiw-steps">
    {steps.map((s, i) => (
      <div class="hiw-step">
        <span class="hiw-num">{s.n}</span>
        <div class="hiw-content">
          <p class="hiw-step-label">{s.label}</p>
          <p class="hiw-step-detail">{s.detail}</p>
        </div>
        {i < steps.length - 1 && <span class="hiw-arrow" aria-hidden="true">→</span>}
      </div>
    ))}
  </div>
</div>

<style>
  .how-it-works {
    margin: 28px 0;
    padding: 18px 20px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .hiw-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
    margin: 0 0 14px;
  }

  .hiw-steps {
    display: flex;
    gap: 0;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .hiw-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    flex: 1;
    min-width: 140px;
  }

  .hiw-num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(167, 139, 250, 0.15);
    border: 1px solid rgba(167, 139, 250, 0.3);
    color: var(--primary);
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .hiw-content {
    flex: 1;
  }

  .hiw-step-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 3px;
    line-height: 1.3;
  }

  .hiw-step-detail {
    font-size: 12px;
    color: var(--dim);
    line-height: 1.5;
    margin: 0;
  }

  .hiw-arrow {
    color: var(--dim);
    font-size: 16px;
    padding: 4px 8px 0;
    flex-shrink: 0;
    align-self: flex-start;
  }

  @media (max-width: 540px) {
    .hiw-steps {
      flex-direction: column;
      gap: 14px;
    }

    .hiw-arrow {
      display: none;
    }
  }
</style>
