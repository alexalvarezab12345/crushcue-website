---
import Base from './Base.astro';
import ConversationBubbles from '../components/ConversationBubbles.astro';
import AnalysisCard from '../components/AnalysisCard.astro';
import ScenarioCards from '../components/ScenarioCards.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import RelatedSituations from '../components/RelatedSituations.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  publishedDate?: string;
  ctaPrelude?: string;
  conversationExample?: Array<{ sender: 'you' | 'them'; text: string }>;
  analysisCard?: { signal: string; confidence: 'high' | 'medium' | 'low'; insight: string; recommendation: string };
  scenarioCards?: Array<{ label: string; description: string }>;
  relatedSlugs?: string[];
  socialProofNote?: string;
}

const {
  title,
  description,
  noindex = false,
  publishedDate,
  ctaPrelude,
  conversationExample,
  analysisCard,
  scenarioCards,
  relatedSlugs,
  socialProofNote,
} = Astro.props;

// Hydrate related slugs into entries at build time — fully static
let relatedEntries: Array<{ id: string; title: string; metaDescription?: string }> = [];
if (relatedSlugs?.length) {
  const all = await getCollection('seo');
  relatedEntries = all
    .filter(e => relatedSlugs.includes(e.id))
    .map(e => ({ id: e.id, title: e.data.title, metaDescription: e.data.metaDescription }));
}
---

<Base title={title} description={description} noindex={noindex}>
  <main class="container">
    <a class="back-link" href="/">← Back to CrushCue</a>
    <article class="card">

      <header class="page-header">
        <h1 class="page-title">{title}</h1>
        {publishedDate && (
          <p class="byline">By CrushCue Editorial Team — Published {publishedDate}</p>
        )}
      </header>

      {conversationExample?.length && (
        <ConversationBubbles turns={conversationExample} />
      )}

      <div class="prose">
        <slot />
      </div>

      {scenarioCards?.length && (
        <ScenarioCards cards={scenarioCards} />
      )}

      {analysisCard && (
        <AnalysisCard
          signal={analysisCard.signal}
          confidence={analysisCard.confidence}
          insight={analysisCard.insight}
          recommendation={analysisCard.recommendation}
        />
      )}

      {socialProofNote && (
        <p class="social-proof">{socialProofNote}</p>
      )}

      {ctaPrelude && (
        <div class="cta-box">
          <p class="cta-headline">Stop guessing. Get the actual read.</p>
          <p class="cta-body">{ctaPrelude}</p>
          <ul class="cta-bullets">
            <li>Read the situation clearly</li>
            <li>Know exactly what to text</li>
            <li>Stop overthinking it</li>
          </ul>
          <div class="cta-action">
            <a class="cta-button" href="https://apps.apple.com/ro/app/crushcue-ai/id6764087079">Analyze my situation</a>
            <p class="cta-sub">Free to try · App Store</p>
          </div>
        </div>
      )}

      {relatedEntries.length > 0 && (
        <RelatedSituations entries={relatedEntries} />
      )}

      <div class="footer-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>

    </article>
  </main>

  <StickyMobileCTA />
</Base>

<style>
  /* ── Container & shell ── */
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 28px;
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .card {
    background: rgba(23, 23, 31, 0.94);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(18px);
  }

  /* ── Page header (H1 + byline rendered from frontmatter) ── */
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    margin: 0 0 8px;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.2;
    color: var(--text);
  }

  .byline {
    margin: 0;
    font-size: 13px;
    color: var(--dim);
    font-style: italic;
  }

  /* ── Prose: MDX content (starts at ## The Short Answer) ── */
  .prose :global(h2) {
    margin: 36px 0 12px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
  }

  .prose :global(h3) {
    margin: 24px 0 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
  }

  .prose :global(p) {
    margin: 0 0 16px;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
  }

  /* FAQ questions: **bold question** as standalone paragraph */
  .prose :global(p > strong:only-child) {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }

  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
  }

  .prose :global(li) {
    position: relative;
    padding-left: 22px;
    margin-bottom: 10px;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }

  .prose :global(li)::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 700;
  }

  .prose :global(li > strong) {
    color: var(--text);
    font-weight: 700;
  }

  /* ── Social proof ── */
  .social-proof {
    margin: 32px 0 0;
    font-size: 13px;
    color: var(--dim);
    font-style: italic;
    text-align: center;
  }

  /* ── CTA box ── */
  .cta-box {
    margin-top: 28px;
    padding: 22px 26px;
    background: rgba(167, 139, 250, 0.07);
    border: 1px solid rgba(167, 139, 250, 0.22);
    border-radius: 16px;
  }

  .cta-headline {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .cta-body {
    margin: 0 0 14px;
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.6;
  }

  .cta-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
  }

  .cta-bullets li {
    font-size: 12.5px;
    color: var(--primary);
    font-weight: 600;
    padding: 0;
    margin: 0;
  }

  .cta-bullets li::before {
    content: "✓ ";
    font-weight: 700;
  }

  .cta-action {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-block;
    padding: 10px 22px;
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    border-radius: 999px;
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.3);
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  .cta-sub {
    margin: 0;
    font-size: 11.5px;
    color: var(--dim);
  }

  /* ── Footer links ── */
  .footer-links {
    margin-top: 36px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .container {
      padding: 28px 16px 80px;
    }

    .card {
      padding: 22px 20px;
      border-radius: 20px;
    }

    .page-title {
      font-size: 24px;
    }

    .prose :global(h2) {
      font-size: 16px;
      margin-top: 28px;
    }

    .cta-box {
      padding: 18px 20px;
    }

    .cta-action {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
