---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ctaPrelude?: string;
}

const { title, description, noindex = false, ctaPrelude } = Astro.props;
---
<Base title={title} description={description} noindex={noindex}>
  <main class="container">
    <a class="back-link" href="/">← Back to CrushCue</a>
    <article class="card">
      <div class="prose">
        <slot />
      </div>
      {ctaPrelude && (
        <div class="cta-box">
          <p class="cta-body">{ctaPrelude}</p>
          <a class="cta-button" href="/">Try CrushCue — Free</a>
        </div>
      )}
      <div class="footer-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </article>
  </main>
</Base>

<style>
  /* ── Container & shell ── */
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 80px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 28px;
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .card {
    background: rgba(23, 23, 31, 0.94);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(18px);
  }

  /* ── Prose: MDX content ── */

  /* Article title */
  .prose :global(h1) {
    margin: 0 0 6px;
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.2;
    color: var(--text);
  }

  /* Byline: _By CrushCue Editorial Team — Published …_ */
  .prose :global(h1 + p) {
    margin: 0 0 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    color: var(--dim);
    font-style: italic;
    line-height: 1.5;
  }

  /* Section headings */
  .prose :global(h2) {
    margin: 36px 0 12px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
  }

  /* Subsection labels (e.g. ### Example openers) */
  .prose :global(h3) {
    margin: 24px 0 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
  }

  /* Body text */
  .prose :global(p) {
    margin: 0 0 16px;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
  }

  /* FAQ questions: **bold question** as its own paragraph */
  .prose :global(p > strong:only-child) {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }

  /* Lists */
  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
  }

  .prose :global(li) {
    position: relative;
    padding-left: 22px;
    margin-bottom: 10px;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Dash bullet via pseudo-element */
  .prose :global(li)::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 700;
  }

  /* Bold scenario labels inside list items */
  .prose :global(li > strong) {
    color: var(--text);
    font-weight: 700;
  }

  /* ── CTA box ── */
  .cta-box {
    margin-top: 40px;
    padding: 24px 28px;
    background: rgba(167, 139, 250, 0.08);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 14px;
  }

  .cta-body {
    margin: 0 0 16px;
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    padding: 10px 20px;
    background: linear-gradient(135deg, #7c3aed, #a78bfa);
    color: white;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    border-radius: 999px;
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.3);
    transition: opacity 0.2s, transform 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    opacity: 0.95;
  }

  /* ── Footer links ── */
  .footer-links {
    margin-top: 36px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .container {
      padding: 28px 16px 56px;
    }

    .card {
      padding: 22px 20px;
      border-radius: 20px;
    }

    .prose :global(h1) {
      font-size: 24px;
    }

    .prose :global(h2) {
      font-size: 16px;
      margin-top: 28px;
    }

    .cta-box {
      padding: 18px 20px;
    }

    .cta-button {
      display: block;
      text-align: center;
    }
  }
</style>
