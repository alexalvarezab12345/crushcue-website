---
import Base from './Base.astro';
import ConversationBubbles from '../components/ConversationBubbles.astro';
import InlineHook from '../components/InlineHook.astro';
import AnalysisCard from '../components/AnalysisCard.astro';
import ScenarioCards from '../components/ScenarioCards.astro';
import AppScreenshotSection from '../components/AppScreenshotSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SituationQuiz from '../components/SituationQuiz.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';
import RelatedSituations from '../components/RelatedSituations.astro';
import ScrollTriggeredCTA from '../components/ScrollTriggeredCTA.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  publishedDate?: string;
  ctaPrelude?: string;
  clusterKey?: string;
  conversationExample?: Array<{ sender: 'you' | 'them'; text: string }>;
  analysisCard?: { signal: string; confidence: 'high' | 'medium' | 'low'; insight: string; recommendation: string };
  scenarioCards?: Array<{ label: string; description: string }>;
  relatedSlugs?: string[];
  socialProofNote?: string;
}

const {
  title,
  description,
  noindex = false,
  publishedDate,
  ctaPrelude,
  clusterKey,
  conversationExample,
  analysisCard,
  scenarioCards,
  relatedSlugs,
  socialProofNote,
} = Astro.props;

// Hydrate related slugs into entries at build time — fully static
let relatedEntries: Array<{ id: string; title: string; metaDescription?: string }> = [];
if (relatedSlugs?.length) {
  const all = await getCollection('seo');
  relatedEntries = all
    .filter(e => relatedSlugs.includes(e.id))
    .map(e => ({ id: e.id, title: e.data.title, metaDescription: e.data.metaDescription }));
}
---

<Base title={title} description={description} noindex={noindex}>
  <main class="container">
    <a class="back-link" href="/">← Back to CrushCue</a>
    <article class="card">

      <header class="page-header">
        <h1 class="page-title">{title}</h1>
        {publishedDate && (
          <p class="byline">By CrushCue Editorial Team — Published {publishedDate}</p>
        )}
      </header>

      {conversationExample?.length && (
        <ConversationBubbles turns={conversationExample} />
      )}

      <InlineHook />

      <div class="prose">
        <slot />
      </div>

      {scenarioCards?.length && (
        <ScenarioCards cards={scenarioCards} />
      )}

      {analysisCard && (
        <AnalysisCard
          signal={analysisCard.signal}
          confidence={analysisCard.confidence}
          insight={analysisCard.insight}
          recommendation={analysisCard.recommendation}
        />
      )}

      <AppScreenshotSection clusterKey={clusterKey} />

      <HowItWorks />

      <SituationQuiz clusterKey={clusterKey} />

      {socialProofNote && (
        <p class="social-proof">{socialProofNote}</p>
      )}

      {ctaPrelude && (
        <div class="cta-box">
          <p class="cta-headline">Stop guessing. Get the actual read.</p>
          <p class="cta-body">{ctaPrelude}</p>
          <ul class="cta-bullets">
            <li>Read the situation clearly</li>
            <li>Know exactly what to text</li>
            <li>Stop overthinking it</li>
          </ul>
          <div class="cta-action">
            <a class="cta-button" href="https://apps.apple.com/ro/app/crushcue-ai/id6764087079">Analyze my situation</a>
            <p class="cta-sub">Free to try · App Store</p>
          </div>
        </div>
      )}

      {relatedEntries.length > 0 && (
        <RelatedSituations entries={relatedEntries} />
      )}

      <ScrollTriggeredCTA />

      <div class="footer-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>

    </article>
  </main>

  <StickyMobileCTA />
</Base>

<style>
  /* ── Container ── */
  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 20px 100px;
  }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 24px;
    color: #5d5877;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: color 0.2s;
  }

  .back-link:hover { color: #a78bfa; }

  /* ── Article card (glass) ── */
  .card {
    background: rgba(14, 14, 20, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    padding: 40px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.04) inset,
      0 40px 100px rgba(0,0,0,0.4);
    animation: card-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Page header ── */
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .page-title {
    margin: 0 0 10px;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1.18;
    color: #f4f0ff;
  }

  .byline {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    color: #3a3555;
    letter-spacing: 0.01em;
  }

  /* ── Prose ── */
  .prose :global(h2) {
    margin: 38px 0 12px;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.28;
    color: #f4f0ff;
  }

  .prose :global(h3) {
    margin: 26px 0 8px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .prose :global(p) {
    margin: 0 0 16px;
    font-size: 15px;
    font-weight: 400;
    color: #6b667f;
    line-height: 1.78;
  }

  /* Bold question paragraphs */
  .prose :global(p > strong:only-child) {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: #d4cfe8;
    margin-bottom: 4px;
  }

  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
  }

  .prose :global(li) {
    position: relative;
    padding-left: 20px;
    margin-bottom: 10px;
    font-size: 15px;
    color: #6b667f;
    line-height: 1.7;
  }

  .prose :global(li)::before {
    content: "—";
    position: absolute;
    left: 0;
    color: #5d3fa0;
    font-weight: 700;
  }

  .prose :global(li > strong) {
    color: #d4cfe8;
    font-weight: 700;
  }

  /* ── Social proof ── */
  .social-proof {
    margin: 32px 0 0;
    font-size: 12.5px;
    color: #3a3555;
    text-align: center;
    letter-spacing: 0.01em;
  }

  /* ── CTA box ── */
  .cta-box {
    margin-top: 32px;
    padding: 24px 26px;
    background: rgba(109, 40, 217, 0.06);
    border: 1px solid rgba(109, 40, 217, 0.16);
    border-radius: 18px;
  }

  .cta-headline {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #f4f0ff;
  }

  .cta-body {
    margin: 0 0 16px;
    font-size: 13.5px;
    font-weight: 400;
    color: #6b667f;
    line-height: 1.65;
  }

  .cta-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }

  .cta-bullets li {
    font-size: 12px;
    color: #8b5cf6;
    font-weight: 600;
    padding: 0;
    margin: 0;
    letter-spacing: 0.01em;
  }

  .cta-bullets li::before {
    content: "✓ ";
    font-weight: 700;
  }

  .cta-action {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* Premium CTA button — same shimmer as homepage */
  .cta-button {
    display: inline-flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 11px 24px;
    background: #7c3aed;
    color: #fff;
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: -0.01em;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.25s ease,
      background 0.25s ease;
    white-space: nowrap;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 35%, rgba(255,255,255,0.15) 50%, transparent 65%);
    transform: translateX(-100%);
    transition: transform 0.55s ease;
  }

  .cta-button:hover::before { transform: translateX(100%); }

  .cta-button:hover {
    transform: translateY(-2px) scale(1.02);
    background: #6d28d9;
    box-shadow:
      0 0 0 3px rgba(139,92,246,0.18),
      0 6px 20px rgba(109,40,217,0.35),
      inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .cta-sub {
    margin: 0;
    font-size: 11.5px;
    color: #3a3555;
  }

  /* ── Footer links ── */
  .footer-links {
    margin-top: 36px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: #3d3a52;
    text-decoration: none;
    font-size: 12.5px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #8b5cf6; }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .container { padding: 24px 16px 80px; }

    .card {
      padding: 22px 18px;
      border-radius: 20px;
    }

    .page-title { font-size: 22px; }

    .prose :global(h2) {
      font-size: 16px;
      margin-top: 30px;
    }

    .cta-box { padding: 18px 18px; }

    .cta-action {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
