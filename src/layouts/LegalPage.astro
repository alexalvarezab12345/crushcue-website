---
import Base from './Base.astro';

interface FooterLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  footerLinks: FooterLink[];
}

const { title, description, noindex, footerLinks } = Astro.props;
---
<Base title={title} description={description} noindex={noindex}>
  <main class="container">
    <a class="back-link" href="/">← Back to CrushCue</a>
    <section class="card">
      <slot />
      <div class="footer-links">
        {footerLinks.map(link => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </section>
  </main>
</Base>

<style>
  .container {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 20px 72px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 28px;
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  .card {
    background: rgba(23, 23, 31, 0.94);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 38px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(18px);
  }

  .footer-links {
    margin-top: 34px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--primary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .container {
      padding: 28px 14px 48px;
    }

    .card {
      padding: 24px;
      border-radius: 20px;
    }
  }
</style>
